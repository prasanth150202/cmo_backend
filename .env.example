# Project Settings
PROJECT_NAME="CMO Dashboard SaaS"
API_V1_STR="/api/v1"
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Supabase Configuration
# Create a project at https://supabase.io/
SUPABASE_URL="yoursupabaseurl"
SUPABASE_KEY="yoursupabaseannonkey"
SUPABASE_SERVICE_ROLE_KEY="yoursupabaseservicerolekey"

# Meta (Facebook) Configuration (Internal System User)
# Create a System User at https://business.facebook.com/
META_SYSTEM_USER_TOKEN="yourmetasystemtoken"
META_APP_ID="yourmetaappid"
META_APP_SECRET="yourmetaappsecret"

# Google Ads Configuration
GOOGLE_DEVELOPER_TOKEN="yourgoogletoken"
GOOGLE_CUSTOMER_ID="yourgooglecustomerid"
GOOGLE_CLIENT_ID="yourgoogleclientid"
GOOGLE_CLIENT_SECRET="yourgoogleclientsecret"
GOOGLE_REFRESH_TOKEN="yourgooglerefreshtoken"

# AI Configuration
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="..."
